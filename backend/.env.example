# =============================================================================
# Kisan Mitra Backend — Environment Variables Template
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in REAL values in .env
#   3. NEVER commit .env to git — it is listed in .gitignore
#   4. NEVER share or log the values of secret keys
# =============================================================================

# ── AI / ML ──────────────────────────────────────────────────────────────────
# Gemini API key from Google AI Studio (https://aistudio.google.com/app/apikey)
# Used for: AI Advisor fallback, Disease Vision fallback, Fertilizer fallback,
#           Crop Recommendation fallback, Leaf verification
GEMINI_API_KEY=your_gemini_api_key_here

# ── Weather ───────────────────────────────────────────────────────────────────
# OpenWeatherMap API key (https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ── Market Data ───────────────────────────────────────────────────────────────
# data.gov.in Mandi API key (https://data.gov.in)
MANDI_API_KEY=your_mandi_api_key_here

# ── Application ───────────────────────────────────────────────────────────────
# Environment: development | production
APP_ENV=production

# Enable filename-bypass for testing (NEVER enable in production)
KISAN_ALLOW_FILENAME_BYPASS=0

# ── Firebase (for validation scripts only) ────────────────────────────────────
# Firebase Web API key — used only in scratch/validation scripts
# (This key is public by design but we keep it out of source files)
FIREBASE_WEB_API_KEY=your_firebase_web_api_key_here
