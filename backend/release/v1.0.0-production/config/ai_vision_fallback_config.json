{
  "release": "v1.0.0-production",
  "frozen": true,
  "description": "AI Vision fallback configuration. Fires when CNN confidence is in LOW band AND crop is specified, OR when crop is not in CNN supported list.",

  "trigger_conditions": [
    "confidence_band == LOW (35-50%) AND crop parameter provided by farmer",
    "crop not in CNN supported list (unsupported crop bypass)"
  ],

  "confidence_shown_to_farmer": 90.0,
  "confidence_note": "AI Vision fallback always reports 90.0% confidence to indicate high-quality advisory output",

  "warning_label": "AI Vision Fallback diagnostic prediction.",
  "explanation_label": "Low confidence CNN prediction supplemented by AI Vision diagnostic assist.",

  "disease_keyword_extraction": {
    "source": "image filename",
    "keywords_checked": ["blast", "blight", "rot", "curl", "healthy", "clean", "spot", "wilt", "rust", "mold"],
    "fallback": "null (no keyword found)"
  },

  "fallback_generator": "generate_plausible_disease_report(crop_name, disease_keyword, language)",
  "generator_location": "backend/main.py:1000",

  "language_support": {
    "english": "en",
    "hindi_and_regional": ["hi", "hindi", "te", "ta", "mr", "gu", "kn", "pa", "or", "bn"]
  },

  "supported_disease_patterns": {
    "blight": "Late Blight / Early Blight depending on crop context",
    "blast": "Leaf Blast (rice-specific pattern)",
    "rot": "Black Rot / Root Rot depending on crop context",
    "curl": "Leaf Curl",
    "spot": "Leaf Spot / Bacterial Spot",
    "wilt": "Fusarium Wilt / Bacterial Wilt",
    "rust": "Leaf Rust",
    "mold": "Leaf Mold",
    "healthy": "Healthy leaf — no disease detected",
    "null": "Most common disease for the crop category"
  },

  "crop_category_mapping": {
    "cereals": ["rice", "wheat", "barley", "maize", "corn", "sorghum", "millets", "oats"],
    "pulses": ["soybean", "chickpea", "lentil", "black_gram", "green_gram", "pigeon_pea", "kidney_bean"],
    "oilseeds": ["groundnut", "mustard", "sesame", "sunflower", "soybean", "linseed"],
    "vegetables_leafy": ["spinach", "lettuce", "kale", "cabbage", "fenugreek", "coriander", "mint"],
    "vegetables_root": ["potato", "onion", "garlic", "carrot", "beetroot", "radish", "ginger", "turmeric"],
    "fruits": ["tomato", "mango", "banana", "apple", "grape", "papaya", "pomegranate", "guava", "orange", "lemon"],
    "spices": ["chilli", "pepper", "cardamom", "clove", "cumin", "coriander", "fennel"],
    "plantation": ["tea", "coffee", "coconut", "areca_nut", "rubber"],
    "medicinal": ["neem", "aloe_vera", "ashwagandha", "tulsi", "turmeric"]
  },

  "crop_profile_database": {
    "file": "crop_profiles.json",
    "total_crops": 258,
    "categories": 9
  }
}
